#!/usr/bin/env bash
# ghstats - Track GitHub repo stars & forks with daily deltas
#
# Usage:
#   ghstats                          # use default repos from config
#   ghstats owner/repo [owner/repo]  # specify repos on command line
#   ghstats -w [SECONDS]             # watch mode, refresh every N seconds (default 300)
#   ghstats --watch 60 owner/repo    # watch a specific repo every 60s
#
# Config file: ~/.config/ghstats/repos.conf  (one owner/repo per line)
# History:     ~/.config/ghstats/history.json

set -euo pipefail

# ── Parse flags ──────────────────────────────────────────────────
WATCH=false
WATCH_INTERVAL=21600  # default 6 hours
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -w|--watch)
      WATCH=true
      # If next arg is a number, use it as interval
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        WATCH_INTERVAL="$2"
        shift
      fi
      shift
      ;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done
set -- "${POSITIONAL[@]+"${POSITIONAL[@]}"}"

CONFIG_DIR="${HOME}/.config/ghstats"
REPOS_CONF="${CONFIG_DIR}/repos.conf"
HISTORY_FILE="${CONFIG_DIR}/history.json"
TODAY=$(date -u +%Y-%m-%d)

# ── Colors & symbols ────────────────────────────────────────────
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

UP_ARROW="▲"
DOWN_ARROW="▼"
DASH="─"

# ── Notifications ────────────────────────────────────────────────
notify_new_issues() {
  local repo="$1" count="$2"
  local url
  url=$(gh api "search/issues?q=repo:${repo}+type:issue+state:open&sort=created&order=desc&per_page=1" \
    --jq '.items[0].html_url' 2>/dev/null) || return 0
  [[ -z "${url}" || "${url}" == "null" ]] && return 0
  local msg="${count} new issue(s) on ${repo}"
  if command -v terminal-notifier &>/dev/null; then
    terminal-notifier -title "New Issue" -message "${msg}" -sound Pop -open "${url}" 2>/dev/null &
  else
    osascript -e "display notification \"${msg}\" with title \"New Issue\" sound name \"Pop\"" 2>/dev/null || true
  fi
}

notify_new_prs() {
  local repo="$1" count="$2"
  local url
  url=$(gh api "search/issues?q=repo:${repo}+type:pr+state:open&sort=created&order=desc&per_page=1" \
    --jq '.items[0].html_url' 2>/dev/null) || return 0
  [[ -z "${url}" || "${url}" == "null" ]] && return 0
  local msg="${count} new PR(s) on ${repo}"
  if command -v terminal-notifier &>/dev/null; then
    terminal-notifier -title "New PR" -message "${msg}" -sound Pop -open "${url}" 2>/dev/null &
  else
    osascript -e "display notification \"${msg}\" with title \"New PR\" sound name \"Pop\"" 2>/dev/null || true
  fi
}

# ── Helpers ──────────────────────────────────────────────────────
ensure_config_dir() {
  mkdir -p "${CONFIG_DIR}"
  [[ -f "${HISTORY_FILE}" ]] || echo '{}' > "${HISTORY_FILE}"
}

# Seed the default repos config if it doesn't exist
seed_defaults() {
  if [[ ! -f "${REPOS_CONF}" ]]; then
    cat > "${REPOS_CONF}" <<'EOF'
dravr-ai/dravr-embacle
Atmosphere/atmosphere
jfarcand/iphone-mirroir-mcp
jfarcand/mirroir-skills
EOF
  fi
}

load_repos() {
  if [[ $# -gt 0 ]]; then
    # Repos from command line — strip full GitHub URLs to owner/repo
    for arg in "$@"; do
      echo "${arg}" | sed -E 's|https?://github\.com/||' | sed 's|/$||'
    done
  elif [[ -f "${REPOS_CONF}" ]]; then
    grep -v '^\s*#' "${REPOS_CONF}" | grep -v '^\s*$' | \
      sed -E 's|https?://github\.com/||' | sed 's|/$||'
  else
    echo "No repos specified. Pass them as arguments or add to ${REPOS_CONF}" >&2
    exit 1
  fi
}

fetch_repo() {
  local repo="$1"
  local canonical_repo repo_data issues_count prs_count views_count clones_count
  # Resolve canonical name and fetch repo data in one call
  local full_data
  full_data=$(gh api "repos/${repo}" 2>/dev/null) || return 1
  canonical_repo=$(echo "${full_data}" | jq -r '.full_name')
  repo_data=$(echo "${full_data}" | jq '{stars: .stargazers_count, forks: .forks_count, watchers: .subscribers_count}')
  # Use repos API instead of search API (search has 30 req/min limit)
  local open_total
  open_total=$(echo "${full_data}" | jq '.open_issues_count')
  prs_count=$(gh api "repos/${canonical_repo}/pulls?state=open&per_page=100" --jq 'length' 2>/dev/null) || prs_count=0
  issues_count=$(( open_total - prs_count ))
  # Traffic requires push access — gracefully degrade
  views_count=$(gh api "repos/${canonical_repo}/traffic/views" --jq '.count' 2>/dev/null) || views_count=null
  clones_count=$(gh api "repos/${canonical_repo}/traffic/clones" --jq '.count' 2>/dev/null) || clones_count=null
  echo "${repo_data}" | jq \
    --argjson i "${issues_count}" --argjson p "${prs_count}" \
    --argjson v "${views_count}" --argjson c "${clones_count}" \
    '. + {issues: $i, prs: $p, views: $v, clones: $c}'
}

get_previous() {
  local repo="$1"
  local key
  key=$(echo "${repo}" | tr '/' '_')
  local entry
  entry=$(jq -r --arg k "${key}" '.[$k] // empty' "${HISTORY_FILE}" 2>/dev/null)
  if [[ -z "${entry}" || "${entry}" == "null" ]]; then
    return
  fi

  local current_date
  current_date=$(echo "${entry}" | jq -r '.current.date // empty' 2>/dev/null || true)

  if [[ -z "${current_date}" || "${current_date}" == "null" ]]; then
    # Old format (flat {stars, forks, watchers, date}): return as-is for comparison
    local old_date
    old_date=$(echo "${entry}" | jq -r '.date // empty' 2>/dev/null || true)
    if [[ -n "${old_date}" && "${old_date}" != "null" ]]; then
      echo "${entry}"
    fi
    return
  fi

  if [[ "${current_date}" == "${TODAY}" ]]; then
    # Already ran today — compare against the saved previous snapshot
    echo "${entry}" | jq -r '.previous // empty' 2>/dev/null || true
  else
    # First run today — compare against current (which is from a prior day)
    echo "${entry}" | jq -r '.current // empty' 2>/dev/null || true
  fi
}

save_today() {
  local repo="$1" stars="$2" forks="$3" watchers="$4" issues="$5" prs="$6" views="$7" clones="$8"
  local key
  key=$(echo "${repo}" | tr '/' '_')
  local tmp
  tmp=$(mktemp)

  local current_date
  current_date=$(jq -r --arg k "${key}" '.[$k].current.date // empty' "${HISTORY_FILE}" 2>/dev/null || true)

  local jq_current='{stars: $s, forks: $f, watchers: $w, issues: $i, prs: $p, views: $v, clones: $c, date: $d}'
  local jq_args=(--arg k "${key}" --argjson s "${stars}" --argjson f "${forks}" --argjson w "${watchers}" --argjson i "${issues}" --argjson p "${prs}" --argjson v "${views}" --argjson c "${clones}" --arg d "${TODAY}")

  if [[ -z "${current_date}" || "${current_date}" == "null" ]]; then
    # Check for old format and migrate
    local old_date
    old_date=$(jq -r --arg k "${key}" '.[$k].date // empty' "${HISTORY_FILE}" 2>/dev/null || true)
    if [[ -n "${old_date}" && "${old_date}" != "null" && "${old_date}" != "${TODAY}" ]]; then
      jq "${jq_args[@]}" \
         ".[\$k] = {previous: .[\$k], current: ${jq_current}}" \
         "${HISTORY_FILE}" > "${tmp}" && mv "${tmp}" "${HISTORY_FILE}"
    else
      jq "${jq_args[@]}" \
         ".[\$k] = {current: ${jq_current}}" \
         "${HISTORY_FILE}" > "${tmp}" && mv "${tmp}" "${HISTORY_FILE}"
    fi
  elif [[ "${current_date}" != "${TODAY}" ]]; then
    # New day: rotate current → previous, then save new current
    jq "${jq_args[@]}" \
       ".[\$k] = {previous: .[\$k].current, current: ${jq_current}}" \
       "${HISTORY_FILE}" > "${tmp}" && mv "${tmp}" "${HISTORY_FILE}"
  else
    # Same day: just update current, keep previous intact
    jq "${jq_args[@]}" \
       ".[\$k].current = ${jq_current}" \
       "${HISTORY_FILE}" > "${tmp}" && mv "${tmp}" "${HISTORY_FILE}"
  fi
}

format_delta() {
  local current="$1" previous="$2"
  if [[ -z "${current}" || "${current}" == "null" ]]; then
    printf "${DIM}%-8s${RESET}" "--"
    return
  fi
  if [[ -z "${previous}" || "${previous}" == "null" ]]; then
    printf "${DIM}%-8s${RESET}" "new"
    return
  fi
  local diff=$(( current - previous ))
  if (( diff > 0 )); then
    printf "${GREEN}%-8s${RESET}" "+${diff}"
  elif (( diff < 0 )); then
    printf "${RED}%-8s${RESET}" "${diff}"
  else
    printf "${DIM}%-8s${RESET}" "0"
  fi
}

COL="──────────"  # 10-char column separator

print_separator() {
  local w="$1"
  printf "├"
  for i in $(seq 1 $((w + 2))); do printf "─"; done
  local sep_cols="" ; for i in $(seq 1 14); do sep_cols+="┼${COL}"; done
  printf "${sep_cols}┤\n"
}

# ── Main ─────────────────────────────────────────────────────────
ensure_config_dir
seed_defaults

REPOS=()
while IFS= read -r line; do
  REPOS+=("${line}")
done < <(load_repos "$@")

if [[ ${#REPOS[@]} -eq 0 ]]; then
  echo "No repos to track." >&2
  exit 1
fi

# Find longest repo name for column sizing
max_len=10
for repo in "${REPOS[@]}"; do
  (( ${#repo} > max_len )) && max_len=${#repo}
done

display_stats() {
  # Refresh date (UTC) so watch mode rotates history at 00:00 UTC
  TODAY=$(date -u +%Y-%m-%d)
  local now
  now=$(date '+%Y-%m-%d %H:%M:%S')
  local last_prev_date=""

  # ── Header ─────────────────────────────────────────────────────
  echo ""
  if [[ "${WATCH}" == true ]]; then
    printf "${BOLD}${CYAN}  GitHub Stats ${RESET}${DIM}(${now})  ⟳ every ${WATCH_INTERVAL}s — Ctrl-C to stop${RESET}\n"
  else
    printf "${BOLD}${CYAN}  GitHub Stats ${RESET}${DIM}(${now})${RESET}\n"
  fi
  echo ""

  # Table header
  printf "┌"
  for i in $(seq 1 $((max_len + 2))); do printf "─"; done
  local hdr_cols="" ; for i in $(seq 1 14); do hdr_cols+="┬${COL}"; done
  printf "${hdr_cols}┐\n"

  printf "│ ${BOLD}%-${max_len}s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │ ${BOLD}%8s${RESET} │ ${BOLD}%-8s${RESET} │\n" \
    "Repository" "Stars" "Delta" "Forks" "Delta" "Watch" "Delta" "Issues" "Delta" "PRs" "Delta" "Views" "Delta" "Clones" "Delta"

  print_separator "${max_len}"

  # ── Fetch & display ───────────────────────────────────────────
  local errors=()
  for repo in "${REPOS[@]}"; do
    local data
    data=$(fetch_repo "${repo}" 2>/dev/null || true)

    if [[ -z "${data}" ]]; then
      errors+=("${repo}")
      printf "│ ${RED}%-${max_len}s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │ ${DIM}%8s${RESET} │ ${DIM}%-8s${RESET} │\n" \
        "${repo}" "err" "--" "err" "--" "err" "--" "err" "--" "err" "--" "err" "--" "err" "--"
      continue
    fi

    local stars forks watchers issues prs views clones
    local prev prev_stars prev_forks prev_watchers prev_issues prev_prs prev_views prev_clones prev_date
    local stars_delta forks_delta watchers_delta issues_delta prs_delta views_delta clones_delta
    stars=$(echo "${data}" | jq -r '.stars')
    forks=$(echo "${data}" | jq -r '.forks')
    watchers=$(echo "${data}" | jq -r '.watchers')
    issues=$(echo "${data}" | jq -r '.issues')
    prs=$(echo "${data}" | jq -r '.prs')
    views=$(echo "${data}" | jq -r '.views')
    clones=$(echo "${data}" | jq -r '.clones')

    prev=$(get_previous "${repo}")
    prev_stars=$(echo "${prev}" | jq -r '.stars // empty' 2>/dev/null || true)
    prev_forks=$(echo "${prev}" | jq -r '.forks // empty' 2>/dev/null || true)
    prev_watchers=$(echo "${prev}" | jq -r '.watchers // empty' 2>/dev/null || true)
    prev_issues=$(echo "${prev}" | jq -r '.issues // empty' 2>/dev/null || true)
    prev_prs=$(echo "${prev}" | jq -r '.prs // empty' 2>/dev/null || true)
    prev_views=$(echo "${prev}" | jq -r '.views // empty' 2>/dev/null || true)
    prev_clones=$(echo "${prev}" | jq -r '.clones // empty' 2>/dev/null || true)
    prev_date=$(echo "${prev}" | jq -r '.date // empty' 2>/dev/null || true)
    [[ -n "${prev_date}" && "${prev_date}" != "null" ]] && last_prev_date="${prev_date}"

    stars_delta=$(format_delta "${stars}" "${prev_stars}")
    forks_delta=$(format_delta "${forks}" "${prev_forks}")
    watchers_delta=$(format_delta "${watchers}" "${prev_watchers}")
    issues_delta=$(format_delta "${issues}" "${prev_issues}")
    prs_delta=$(format_delta "${prs}" "${prev_prs}")
    views_delta=$(format_delta "${views}" "${prev_views}")
    clones_delta=$(format_delta "${clones}" "${prev_clones}")

    # Notify on new issues/PRs
    if [[ -n "${prev_issues}" && "${prev_issues}" != "null" && "${issues}" != "null" ]]; then
      local issues_diff=$(( issues - prev_issues ))
      if (( issues_diff > 0 )); then
        local canonical
        canonical=$(gh api "repos/${repo}" --jq '.full_name' 2>/dev/null) || canonical="${repo}"
        notify_new_issues "${canonical}" "${issues_diff}"
      fi
    fi
    if [[ -n "${prev_prs}" && "${prev_prs}" != "null" && "${prs}" != "null" ]]; then
      local prs_diff=$(( prs - prev_prs ))
      if (( prs_diff > 0 )); then
        local canonical
        canonical=$(gh api "repos/${repo}" --jq '.full_name' 2>/dev/null) || canonical="${repo}"
        notify_new_prs "${canonical}" "${prs_diff}"
      fi
    fi

    # Format views/clones: show "--" if no push access (null)
    local views_display clones_display
    if [[ "${views}" == "null" ]]; then views_display="--"; else views_display="${views}"; fi
    if [[ "${clones}" == "null" ]]; then clones_display="--"; else clones_display="${clones}"; fi

    printf "│ %-${max_len}s │ %8s │ " "${repo}" "${stars}"
    printf "${stars_delta}"
    printf " │ %8s │ " "${forks}"
    printf "${forks_delta}"
    printf " │ %8s │ " "${watchers}"
    printf "${watchers_delta}"
    printf " │ %8s │ " "${issues}"
    printf "${issues_delta}"
    printf " │ %8s │ " "${prs}"
    printf "${prs_delta}"
    printf " │ %8s │ " "${views_display}"
    printf "${views_delta}"
    printf " │ %8s │ " "${clones_display}"
    printf "${clones_delta}"
    printf " │\n"

    save_today "${repo}" "${stars}" "${forks}" "${watchers}" "${issues}" "${prs}" "${views}" "${clones}" || true
  done

  # Table footer
  printf "└"
  for i in $(seq 1 $((max_len + 2))); do printf "─"; done
  local ftr_cols="" ; for i in $(seq 1 14); do ftr_cols+="┴${COL}"; done
  printf "${ftr_cols}┘\n"

  if [[ -n "${last_prev_date}" ]]; then
    printf "\n${DIM}  Δ compared to: ${last_prev_date}${RESET}\n"
  else
    printf "\n${DIM}  First run — deltas will appear on next run.${RESET}\n"
  fi

  if [[ ${#errors[@]} -gt 0 ]]; then
    printf "\n${YELLOW}  ⚠ Could not fetch: %s${RESET}\n" "${errors[*]}"
  fi

  echo ""
}

# ── Run (once or watch) ─────────────────────────────────────────
if [[ "${WATCH}" == true ]]; then
  trap 'printf "\033[?25h\n${DIM}  Stopped.${RESET}\n"; exit 0' INT
  printf '\033[?25l'
  while true; do
    printf '\033[H\033[2J\033[3J' > /dev/tty
    display_stats
    sleep "${WATCH_INTERVAL}"
  done
else
  display_stats
fi
