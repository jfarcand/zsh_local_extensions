#!/bin/bash
# ABOUTME: Kill GitHub Actions workflow runs by branch or keep only latest per workflow on a branch
# ABOUTME: Uses gh CLI to cancel in_progress and queued workflow runs

set -e

# Default limit for gh run list
LIMIT=30
WATCH=false
WATCH_INTERVAL=10

usage() {
    cat << EOF
Usage: killActions [OPTIONS]

Kill GitHub Actions workflow runs.

Options:
  -b, --branch <name>      Cancel all runs for a specific branch
  -a, --all                Cancel all runs (use with -e to keep latest per workflow)
  -e, --except <name>      Keep only the LATEST run per workflow on this branch
  -l, --last <n>           Fetch last N runs (default: $LIMIT)
  -w, --watch              Watch until all runs complete, then show final status
  -h, --help               Show this help message

Examples:
  killActions -b main                  # Cancel all runs on 'main' branch
  killActions -b feature/foo           # Cancel all runs on 'feature/foo' branch
  killActions -a -e main               # Keep only LATEST per workflow on main, cancel rest
  killActions --all --except main      # Same as above (long form)
  killActions -a -e main -l 50         # Check last 50 runs
  killActions -a -e main --last 100    # Check last 100 runs
  killActions -a -e main -w            # Cancel and watch until all complete

Note: Only cancels 'in_progress' and 'queued' runs.
EOF
    exit 0
}

list_active_runs() {
    echo ""
    echo "📋 Current active runs: (gh run list --status in_progress)"
    local runs=$(gh run list --status in_progress --limit "$LIMIT" --json databaseId,headBranch,name,status --jq '.[] | "  #\(.databaseId) [\(.status)] \(.headBranch) - \(.name)"' 2>/dev/null)
    runs+=$'\n'$(gh run list --status queued --limit "$LIMIT" --json databaseId,headBranch,name,status --jq '.[] | "  #\(.databaseId) [\(.status)] \(.headBranch) - \(.name)"' 2>/dev/null)

    runs=$(echo "$runs" | grep -v '^$' | sort -u)

    if [ -z "$runs" ]; then
        echo "  ✅ No active runs"
        return 1
    else
        echo "$runs"
        return 0
    fi
}

watch_until_complete() {
    local filter_branch="$1"
    # Track previous run IDs to detect completions
    local prev_run_ids=""
    # Track all completions for display
    local completed_runs=""
    # Track head SHAs of runs we're watching (to group related runs)
    local watched_shas=""

    while true; do
        # Get current active runs with details (including createdAt and headSha for grouping)
        local current_runs=$(gh run list --status in_progress --limit "$LIMIT" --json databaseId,headBranch,name,createdAt,headSha --jq '.[] | "\(.databaseId)|\(.headBranch)|\(.name)|\(.createdAt)|\(.headSha)"' 2>/dev/null)
        current_runs+=$'\n'$(gh run list --status queued --limit "$LIMIT" --json databaseId,headBranch,name,createdAt,headSha --jq '.[] | "\(.databaseId)|\(.headBranch)|\(.name)|\(.createdAt)|\(.headSha)"' 2>/dev/null)
        current_runs=$(echo "$current_runs" | grep -v '^$' | sort -u)

        # On first run, collect the head SHAs we're watching
        if [ -z "$watched_shas" ]; then
            watched_shas=$(echo "$current_runs" | cut -d'|' -f5 | sort -u | tr '\n' '|')

            # Fetch completed runs with matching SHAs (same commit batch)
            if [ -n "$watched_shas" ]; then
                local recent_completed
                if [ -n "$filter_branch" ]; then
                    recent_completed=$(gh run list --branch "$filter_branch" --status completed --limit 20 --json databaseId,headBranch,name,conclusion,createdAt,updatedAt,headSha 2>/dev/null)
                else
                    recent_completed=$(gh run list --status completed --limit 20 --json databaseId,headBranch,name,conclusion,createdAt,updatedAt,headSha 2>/dev/null)
                fi
                if [ -n "$recent_completed" ]; then
                    while read -r line; do
                        local sha=$(echo "$line" | jq -r '.headSha')
                        # Only include if SHA matches one of our watched runs
                        if echo "$watched_shas" | grep -qF "$sha"; then
                            local run_id=$(echo "$line" | jq -r '.databaseId')
                            local conclusion=$(echo "$line" | jq -r '.conclusion')
                            local branch=$(echo "$line" | jq -r '.headBranch')
                            local name=$(echo "$line" | jq -r '.name')
                            local created=$(echo "$line" | jq -r '.createdAt')
                            local updated=$(echo "$line" | jq -r '.updatedAt')
                            # Calculate duration
                            local clean_created=$(echo "$created" | sed 's/\.[0-9]*Z$/Z/')
                            local clean_updated=$(echo "$updated" | sed 's/\.[0-9]*Z$/Z/')
                            local start_ts=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$clean_created" "+%s" 2>/dev/null || date -d "$created" "+%s" 2>/dev/null)
                            local end_ts=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$clean_updated" "+%s" 2>/dev/null || date -d "$updated" "+%s" 2>/dev/null)
                            local duration_str=""
                            if [ -n "$start_ts" ] && [ -n "$end_ts" ] && [ "$start_ts" -gt 0 ] && [ "$end_ts" -gt 0 ]; then
                                local dur=$((end_ts - start_ts))
                                [ "$dur" -lt 0 ] && dur=0
                                if [ "$dur" -ge 3600 ]; then
                                    duration_str="$((dur / 3600))h$((dur % 3600 / 60))m"
                                elif [ "$dur" -ge 60 ]; then
                                    duration_str="$((dur / 60))m$((dur % 60))s"
                                else
                                    duration_str="${dur}s"
                                fi
                            fi
                            local icon="✓"
                            [ "$conclusion" = "failure" ] && icon="✗"
                            [ "$conclusion" = "cancelled" ] && icon="⊘"
                            completed_runs+="  $icon #$run_id [$conclusion] $branch - $name ($duration_str)"$'\n'
                        fi
                    done < <(echo "$recent_completed" | jq -c '.[]')
                fi
            fi
        fi

        local current_ids=$(echo "$current_runs" | cut -d'|' -f1 | sort -u | tr '\n' '|')

        # On first run, just record the IDs
        if [ -z "$prev_run_ids" ]; then
            prev_run_ids="$current_ids"
        else
            # Check for completed runs (were in prev but not in current)
            for prev_id in $(echo "$prev_run_ids" | tr '|' '\n' | grep -v '^$'); do
                if ! echo "$current_ids" | grep -qF "|${prev_id}|" && ! echo "$current_ids" | grep -q "^${prev_id}|"; then
                    # This run completed - get its final status with duration
                    local run_data=$(gh run view "$prev_id" --json conclusion,name,headBranch,createdAt,updatedAt 2>/dev/null)
                    if [ -n "$run_data" ]; then
                        local conclusion=$(echo "$run_data" | jq -r '.conclusion')
                        local branch=$(echo "$run_data" | jq -r '.headBranch')
                        local name=$(echo "$run_data" | jq -r '.name')
                        local created=$(echo "$run_data" | jq -r '.createdAt')
                        local updated=$(echo "$run_data" | jq -r '.updatedAt')
                        # Calculate duration in seconds using date
                        local start_ts=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "${created%.*}Z" "+%s" 2>/dev/null || date -d "$created" "+%s" 2>/dev/null)
                        local end_ts=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "${updated%.*}Z" "+%s" 2>/dev/null || date -d "$updated" "+%s" 2>/dev/null)
                        local duration_str=""
                        if [ -n "$start_ts" ] && [ -n "$end_ts" ]; then
                            local dur=$((end_ts - start_ts))
                            if [ "$dur" -ge 3600 ]; then
                                duration_str="$((dur / 3600))h$((dur % 3600 / 60))m"
                            elif [ "$dur" -ge 60 ]; then
                                duration_str="$((dur / 60))m$((dur % 60))s"
                            else
                                duration_str="${dur}s"
                            fi
                        fi
                        # Add to completed runs list
                        local icon="✓"
                        [ "$conclusion" = "failure" ] && icon="✗"
                        [ "$conclusion" = "cancelled" ] && icon="⊘"
                        completed_runs+="  $icon #$prev_id [$conclusion] $branch - $name ($duration_str)"$'\n'
                    fi
                fi
            done
            prev_run_ids="$current_ids"
        fi

        local in_progress
        in_progress=$(echo "$current_runs" | grep -c '.' 2>/dev/null) || in_progress=0

        # Clear screen and redraw
        printf "\033[2J\033[H"
        echo "👀 Watching for completion (Ctrl+C to stop)..."
        echo ""

        # Show completed runs
        if [ -n "$completed_runs" ]; then
            echo "📋 Completed:"
            echo "$completed_runs" | grep -v '^$'
            echo "────────────────────────────────────────────────────────────"
        fi

        if [ "$in_progress" -eq 0 ]; then
            echo ""
            echo "✅ All runs completed!"
            break
        else
            # Show running workflows with elapsed time
            echo "🔄 Running ($in_progress active):"
            local now_ts=$(date "+%s")
            echo "$current_runs" | while IFS='|' read -r run_id branch name created headsha || [ -n "$run_id" ]; do
                if [ -n "$run_id" ]; then
                    local elapsed_str=""
                    if [ -n "$created" ]; then
                        # Remove milliseconds if present: 2025-12-04T20:15:43.123Z → 2025-12-04T20:15:43Z
                        local clean_ts=$(echo "$created" | sed 's/\.[0-9]*Z$/Z/')
                        local start_ts=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$clean_ts" "+%s" 2>/dev/null || date -d "$created" "+%s" 2>/dev/null)
                        if [ -n "$start_ts" ] && [ "$start_ts" -gt 0 ]; then
                            local elapsed=$((now_ts - start_ts))
                            [ "$elapsed" -lt 0 ] && elapsed=0
                            if [ "$elapsed" -ge 3600 ]; then
                                elapsed_str="$((elapsed / 3600))h$((elapsed % 3600 / 60))m"
                            elif [ "$elapsed" -ge 60 ]; then
                                elapsed_str="$((elapsed / 60))m$((elapsed % 60))s"
                            else
                                elapsed_str="${elapsed}s"
                            fi
                        fi
                    fi
                    echo "  ⏳ #$run_id $branch - $name ($elapsed_str)"
                fi
            done
            echo ""
            echo "(checking every ${WATCH_INTERVAL}s...)"
            sleep "$WATCH_INTERVAL"
        fi
    done
}

cancel_runs_for_branch() {
    local branch="$1"
    echo "🔍 Finding in_progress/queued runs for branch: $branch (last $LIMIT runs)"

    local run_ids=$(gh run list --branch "$branch" --status in_progress --limit "$LIMIT" --json databaseId --jq '.[].databaseId' 2>/dev/null)
    run_ids+=$'\n'$(gh run list --branch "$branch" --status queued --limit "$LIMIT" --json databaseId --jq '.[].databaseId' 2>/dev/null)

    run_ids=$(echo "$run_ids" | grep -v '^$' | sort -u)

    if [ -z "$run_ids" ]; then
        echo "✅ No active runs found for branch: $branch"
        return 0
    fi

    local count=$(echo "$run_ids" | wc -l | tr -d ' ')
    echo "🎯 Found $count run(s) to cancel on branch: $branch"

    echo "$run_ids" | while read -r run_id; do
        if [ -n "$run_id" ]; then
            echo "  ❌ Canceling run #$run_id..."
            gh run cancel "$run_id" 2>/dev/null || echo "    ⚠️  Could not cancel #$run_id (may have already completed)"
        fi
    done

    echo "✅ Done canceling runs for branch: $branch"
}

cancel_all_except_branch() {
    local except_branch="$1"
    echo "🔍 Finding all in_progress/queued runs (keeping only LATEST per workflow on: $except_branch)"

    # Get all runs with branch, workflow name - sorted by run_id descending (highest first)
    # Format: "run_id|branch|workflow_name"
    local all_runs=$(gh run list --status in_progress --limit "$LIMIT" --json databaseId,headBranch,name --jq '.[] | "\(.databaseId)|\(.headBranch)|\(.name)"' 2>/dev/null)
    all_runs+=$'\n'$(gh run list --status queued --limit "$LIMIT" --json databaseId,headBranch,name --jq '.[] | "\(.databaseId)|\(.headBranch)|\(.name)"' 2>/dev/null)

    all_runs=$(echo "$all_runs" | grep -v '^$' | sort -t'|' -k1 -rn | uniq)

    if [ -z "$all_runs" ]; then
        echo "✅ No active runs found"
        return 0
    fi

    # Build list of latest run IDs per workflow on the excepted branch
    # Since we sorted descending, the first occurrence of each workflow is the latest
    local seen_workflows=""
    local keep_ids=""

    while IFS='|' read -r run_id branch workflow; do
        if [ "$branch" = "$except_branch" ]; then
            if ! echo "$seen_workflows" | grep -qF "|${workflow}|"; then
                seen_workflows="${seen_workflows}|${workflow}|"
                keep_ids="${keep_ids}|${run_id}|"
                echo "  📌 Keeping #$run_id (latest '$workflow' on $except_branch)"
            fi
        fi
    done <<< "$all_runs"

    # Now process all runs
    while IFS='|' read -r run_id branch workflow; do
        if [ -n "$run_id" ]; then
            if echo "$keep_ids" | grep -qF "|${run_id}|"; then
                echo "  ⏭️  Skipping run #$run_id (latest $workflow on $branch)"
            elif [ "$branch" = "$except_branch" ]; then
                echo "  ❌ Canceling run #$run_id (older $workflow on $branch)..."
                gh run cancel "$run_id" 2>/dev/null || echo "    ⚠️  Could not cancel #$run_id"
            else
                echo "  ❌ Canceling run #$run_id (branch: $branch)..."
                gh run cancel "$run_id" 2>/dev/null || echo "    ⚠️  Could not cancel #$run_id"
            fi
        fi
    done <<< "$all_runs"

    echo "✅ Done. Kept only latest runs per workflow on '$except_branch', canceled all others"
}

# Parse arguments
BRANCH=""
ALL=false
EXCEPT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -b|--branch)
            BRANCH="$2"
            shift 2
            ;;
        -a|--all)
            ALL=true
            shift
            ;;
        -e|--except)
            EXCEPT="$2"
            shift 2
            ;;
        -l|--last)
            LIMIT="$2"
            shift 2
            ;;
        -w|--watch)
            WATCH=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            echo "❌ Unknown option: $1"
            usage
            ;;
    esac
done

# Validate arguments
if [ -n "$BRANCH" ] && [ "$ALL" = true ]; then
    echo "❌ Error: Cannot use both --branch and --all"
    exit 1
fi

if [ -z "$BRANCH" ] && [ "$ALL" = false ]; then
    echo "❌ Error: Must specify either --branch or --all"
    usage
fi

if [ "$ALL" = true ] && [ -z "$EXCEPT" ]; then
    echo "⚠️  Warning: --all without --except will cancel ALL runs!"
    read -p "Are you sure? (y/N) " confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo "Aborted."
        exit 0
    fi
fi

# Execute
if [ -n "$BRANCH" ]; then
    cancel_runs_for_branch "$BRANCH"
elif [ "$ALL" = true ]; then
    if [ -n "$EXCEPT" ]; then
        cancel_all_except_branch "$EXCEPT"
    else
        # Cancel everything
        echo "🔍 Finding ALL in_progress/queued runs (last $LIMIT runs)..."
        run_ids=$(gh run list --status in_progress --limit "$LIMIT" --json databaseId --jq '.[].databaseId' 2>/dev/null)
        run_ids+=$'\n'$(gh run list --status queued --limit "$LIMIT" --json databaseId --jq '.[].databaseId' 2>/dev/null)
        run_ids=$(echo "$run_ids" | grep -v '^$' | sort -u)

        if [ -z "$run_ids" ]; then
            echo "✅ No active runs found"
            exit 0
        fi

        echo "$run_ids" | while read -r run_id; do
            if [ -n "$run_id" ]; then
                echo "  ❌ Canceling run #$run_id..."
                gh run cancel "$run_id" 2>/dev/null || echo "    ⚠️  Could not cancel #$run_id"
            fi
        done
        echo "✅ Done canceling all runs"
    fi
fi

# Always list remaining active runs at the end
list_active_runs
has_active=$?

# Watch mode if requested and there are still active runs
if [ "$WATCH" = true ] && [ "$has_active" -eq 0 ]; then
    # Pass branch filter: use EXCEPT if set, otherwise BRANCH
    watch_until_complete "${EXCEPT:-$BRANCH}"
fi
