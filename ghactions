#!/usr/bin/env bash
# ghactions - Watch GitHub Actions workflow runs
#
# Usage:
#   ghactions                                  # current repo, main branch
#   ghactions --branch feature-x               # specific branch
#   ghactions -R owner/repo                    # specific repo
#   ghactions -R repo1 -R repo2                # multiple repos
#   ghactions owner/repo1 owner/repo2          # multiple repos (positional)
#   ghactions -w [SECONDS]                     # watch mode (default 300s)
#   ghactions -a                               # aggregate into single table
#
# Config file: ~/.config/ghactions/repos.conf  (one owner/repo per line)
# Sends a desktop notification (with sound) when a workflow turns red.

set -euo pipefail

# ── Parse flags ──────────────────────────────────────────────────
WATCH=false
WATCH_INTERVAL=21600  # default 6 hours
BRANCH="main"
AGGREGATE=false
REPOS=()
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -w|--watch)
      WATCH=true
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        WATCH_INTERVAL="$2"
        shift
      fi
      shift
      ;;
    -a|--aggregate)
      AGGREGATE=true
      shift
      ;;
    -b|--branch)
      BRANCH="${2:?--branch requires a value}"
      shift 2
      ;;
    -R|--repo)
      REPOS+=("${2:?--repo requires a value}")
      shift 2
      ;;
    -h|--help)
      sed -n '2,12p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done
set -- "${POSITIONAL[@]+"${POSITIONAL[@]}"}"

# Positional args are also repos
for arg in "$@"; do
  REPOS+=("$arg")
done

CONFIG_DIR="${HOME}/.config/ghactions"
STATE_FILE="${CONFIG_DIR}/state.json"
REPOS_CONF="${CONFIG_DIR}/repos.conf"
mkdir -p "${CONFIG_DIR}"
[[ -f "${STATE_FILE}" ]] || echo '{}' > "${STATE_FILE}"

# If no repos from flags/args, try config file, then current git repo
if [[ ${#REPOS[@]} -eq 0 ]]; then
  if [[ -f "${REPOS_CONF}" ]]; then
    while IFS= read -r line; do
      [[ -z "${line}" || "${line}" =~ ^[[:space:]]*# ]] && continue
      REPOS+=("${line}")
    done < "${REPOS_CONF}"
  else
    # Fall back to current directory's git remote
    local_repo=$(git remote get-url origin 2>/dev/null | sed -E 's|.*github\.com[:/]||;s|\.git$||' || true)
    if [[ -n "${local_repo}" ]]; then
      REPOS+=("${local_repo}")
    else
      echo "No repos specified. Pass -R owner/repo, positional args, or add to ${REPOS_CONF}" >&2
      exit 1
    fi
  fi
fi

# ── Colors & symbols ────────────────────────────────────────────
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Column widths ────────────────────────────────────────────────
W_STATUS=10
W_STARTED=14
W_FINISHED=14
W_DURATION=10
W_ETA=10
W_FAILSINCE=12

# ── Helpers ──────────────────────────────────────────────────────
notify_failure() {
  local workflow="$1" repo_display="$2"
  osascript -e "display notification \"${workflow} is now failing on ${BRANCH}\" with title \"GitHub Actions: ${repo_display}\" sound name \"Frog\"" 2>/dev/null || true
  printf '\a'
  afplay /System/Library/Sounds/Frog.aiff 2>/dev/null &
}

notify_recovery() {
  local workflow="$1" repo_display="$2"
  osascript -e "display notification \"${workflow} is green again on ${BRANCH}\" with title \"GitHub Actions: ${repo_display}\" sound name \"Hero\"" 2>/dev/null || true
  printf '\a'
  afplay /System/Library/Sounds/Hero.aiff 2>/dev/null &
}

format_duration() {
  local seconds="$1"
  if (( seconds < 60 )); then
    echo "${seconds}s"
  elif (( seconds < 3600 )); then
    printf "%dm %ds" $(( seconds / 60 )) $(( seconds % 60 ))
  else
    printf "%dh %dm" $(( seconds / 3600 )) $(( (seconds % 3600) / 60 ))
  fi
}

parse_epoch() {
  local ts="$1"
  [[ -z "${ts}" || "${ts}" == "null" ]] && { echo 0; return; }
  TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "${ts}" "+%s" 2>/dev/null || echo 0
}

parse_time() {
  local ts="$1"
  [[ -z "${ts}" || "${ts}" == "null" ]] && { echo "--"; return; }
  # Convert UTC timestamp to local time, show as MM-DD HH:MM:SS
  local epoch
  epoch=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "${ts}" "+%s" 2>/dev/null) || { echo "${ts:5:14}"; return; }
  date -j -f "%s" "${epoch}" "+%m-%d %H:%M:%S" 2>/dev/null || echo "${ts:5:14}"
}

# Fetch workflow runs via gh CLI
# Returns JSON array: [{workflowName, workflowId, status, conclusion, startedAt, updatedAt, headSha}, ...]
gh_fetch_runs() {
  local repo="$1"; shift
  local branch="${BRANCH}" limit=100 status_filter="" workflow=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --branch)   branch="$2"; shift 2 ;;
      --limit)    limit="$2"; shift 2 ;;
      --status)   status_filter="$2"; shift 2 ;;
      --workflow) workflow="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local gh_args=(--repo "${repo}" --branch "${branch}" --limit "${limit}")
  [[ -n "${status_filter}" ]] && gh_args+=(--status "${status_filter}")
  [[ -n "${workflow}" ]] && gh_args+=(--workflow "${workflow}")
  gh run list "${gh_args[@]}" \
    --json workflowName,workflowDatabaseId,status,conclusion,startedAt,updatedAt,headSha 2>/dev/null | \
    jq '[.[] | . + {workflowId: .workflowDatabaseId} | del(.workflowDatabaseId)]' 2>/dev/null
}

# Fetch active workflow IDs for a repo (filters out deleted/disabled workflows)
# Returns JSON array of workflow IDs: [123, 456, ...]
gh_active_workflow_ids() {
  local repo="$1"
  gh api "repos/${repo}/actions/workflows" \
    --jq '[.workflows[] | select(.state == "active") | .id]' 2>/dev/null
}

estimate_duration() {
  local repo="$1" workflow_name="$2"

  # Get last successful run's start/end to estimate typical duration
  local runs
  runs=$(gh_fetch_runs "${repo}" --workflow "${workflow_name}" --limit 50 --status completed) || { echo 0; return; }

  # Find first successful run
  local count
  count=$(echo "${runs}" | jq 'length')
  for (( j=0; j<count; j++ )); do
    local c
    c=$(echo "${runs}" | jq -r ".[$j].conclusion" 2>/dev/null || true)
    if [[ "${c}" == "success" ]]; then
      local s e
      s=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$(echo "${runs}" | jq -r ".[$j].startedAt")" "+%s" 2>/dev/null || echo 0)
      e=$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$(echo "${runs}" | jq -r ".[$j].updatedAt")" "+%s" 2>/dev/null || echo 0)
      if (( s > 0 && e > 0 )); then
        echo $(( e - s ))
        return
      fi
    fi
  done
  echo 0
}

find_failing_since() {
  local repo="$1" workflow_name="$2"

  local runs
  runs=$(gh_fetch_runs "${repo}" --workflow "${workflow_name}" --limit 50) || return 0

  # Walk newest to oldest, find the oldest consecutive failure
  local failing_sha="" count
  count=$(echo "${runs}" | jq 'length')
  for (( i=0; i<count; i++ )); do
    local c
    c=$(echo "${runs}" | jq -r ".[$i].conclusion")
    if [[ "${c}" == "failure" ]]; then
      failing_sha=$(echo "${runs}" | jq -r ".[$i].headSha")
    else
      break
    fi
  done
  echo "${failing_sha}"
}

draw_border() {
  local max_len="$1" left="$2" mid="$3" right="$4"
  printf "%s" "${left}"
  printf '%*s' $((max_len + 2)) '' | tr ' ' '─'
  for w in ${W_STATUS} ${W_STARTED} ${W_FINISHED} ${W_DURATION} ${W_ETA} ${W_FAILSINCE}; do
    printf "%s" "${mid}"
    printf '%*s' $((w + 2)) '' | tr ' ' '─'
  done
  printf "%s\n" "${right}"
}

# ── Display for a single repo ───────────────────────────────────
display_repo() {
  local repo="$1" now="$2"
  local repo_flag=()
  [[ -n "${repo}" ]] && repo_flag=(--repo "${repo}")

  local state_key
  state_key=$(echo "${repo}" | tr '/' '_')

  # Fetch latest runs for the branch (curl for public repos, gh for private)
  local runs
  runs=$(gh_fetch_runs "${repo}" --branch "${BRANCH}" --limit 100) || {
    printf "  ${RED}Failed to fetch runs for ${repo}${RESET}\n\n"
    return 0
  }

  # Filter to only active workflows (exclude deleted/disabled)
  local active_ids
  active_ids=$(gh_active_workflow_ids "${repo}" 2>/dev/null) || active_ids="[]"
  if [[ "${active_ids}" != "[]" ]]; then
    runs=$(echo "${runs}" | jq --argjson ids "${active_ids}" \
      '[.[] | select(.workflowId as $wid | $ids | index($wid))]')
  fi

  # Latest run per workflow (group by workflowId to deduplicate renamed workflows)
  local workflows
  workflows=$(echo "${runs}" | jq '
    group_by(.workflowId // .workflowName)
    | map(sort_by(.startedAt) | reverse | .[0])
    | sort_by(.workflowName)
  ')

  local count
  count=$(echo "${workflows}" | jq 'length')

  if (( count == 0 )); then
    printf "  ${DIM}No workflow runs found for ${repo} (${BRANCH})${RESET}\n\n"
    return
  fi

  # Longest workflow name for column sizing
  local max_len=8
  for (( i=0; i<count; i++ )); do
    local name
    name=$(echo "${workflows}" | jq -r ".[$i].workflowName")
    (( ${#name} > max_len )) && max_len=${#name}
  done

  # ── Repo header ──
  printf "  ${BOLD}${CYAN}${repo}${RESET} ${DIM}(${BRANCH})${RESET}\n\n"

  draw_border "${max_len}" "┌" "┬" "┐"

  printf "│ ${BOLD}%-${max_len}s${RESET} │ ${BOLD}%-${W_STATUS}s${RESET} │ ${BOLD}%-${W_STARTED}s${RESET} │ ${BOLD}%-${W_FINISHED}s${RESET} │ ${BOLD}%-${W_DURATION}s${RESET} │ ${BOLD}%-${W_ETA}s${RESET} │ ${BOLD}%-${W_FAILSINCE}s${RESET} │\n" \
    "Workflow" "Status" "Started" "Finished" "Duration" "ETA" "Fail Since"

  draw_border "${max_len}" "├" "┼" "┤"

  # Load previous state for green→red detection
  local prev_state new_state="{}"
  prev_state=$(jq -r --arg k "${state_key}" '.[$k] // {}' "${STATE_FILE}" 2>/dev/null || echo '{}')

  for (( i=0; i<count; i++ )); do
    local name status conclusion started_at updated_at
    name=$(echo "${workflows}" | jq -r ".[$i].workflowName" 2>/dev/null || echo "unknown")
    status=$(echo "${workflows}" | jq -r ".[$i].status" 2>/dev/null || echo "unknown")
    conclusion=$(echo "${workflows}" | jq -r ".[$i].conclusion" 2>/dev/null || echo "unknown")
    started_at=$(echo "${workflows}" | jq -r ".[$i].startedAt" 2>/dev/null || echo "null")
    updated_at=$(echo "${workflows}" | jq -r ".[$i].updatedAt" 2>/dev/null || echo "null")

    # Time
    local started_display finished_display duration_str
    started_display=$(parse_time "${started_at}")
    if [[ "${status}" == "completed" ]]; then
      finished_display=$(parse_time "${updated_at}")
      local s_epoch f_epoch
      s_epoch=$(parse_epoch "${started_at}")
      f_epoch=$(parse_epoch "${updated_at}")
      if (( s_epoch > 0 && f_epoch > 0 )); then
        duration_str=$(format_duration $(( f_epoch - s_epoch )))
      else
        duration_str="--"
      fi
    elif [[ "${status}" == "queued" ]]; then
      finished_display="--"
      duration_str="queued"
    else
      finished_display="--"
      duration_str="running"
    fi

    # Status with color
    local status_display
    case "${status}:${conclusion}" in
      in_progress:*) status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "running")   ;;
      queued:*)      status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "queued")       ;;
      pending:*)     status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "pending")    ;;
      waiting:*)     status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "waiting")    ;;
      requested:*)   status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "requested")  ;;
      *:success)     status_display=$(printf "${GREEN}%-${W_STATUS}s${RESET}" "pass")       ;;
      *:failure)     status_display=$(printf "${RED}%-${W_STATUS}s${RESET}" "FAIL")         ;;
      *:cancelled)   status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "cancelled")    ;;
      *)             status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "${status}")     ;;
    esac

    # ETA for running workflows
    local eta_display
    if [[ "${status}" == "in_progress" || "${status}" == "queued" ]]; then
      local est_seconds elapsed now_epoch remaining
      est_seconds=$(estimate_duration "${repo}" "${name}")
      if (( est_seconds > 0 )); then
        now_epoch=$(date +%s)
        local start_epoch
        start_epoch=$(parse_epoch "${started_at}")
        if (( start_epoch > 0 )); then
          elapsed=$(( now_epoch - start_epoch ))
          remaining=$(( est_seconds - elapsed ))
          if (( remaining > 0 )); then
            eta_display=$(printf "${YELLOW}%-${W_ETA}s${RESET}" "~$(format_duration ${remaining})")
          else
            eta_display=$(printf "${RED}%-${W_ETA}s${RESET}" "+$(format_duration $(( -remaining )))")
          fi
        else
          eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
        fi
      else
        eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
      fi
    else
      eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
    fi

    # Failing since commit
    local fail_display
    if [[ "${conclusion}" == "failure" ]]; then
      local fail_sha
      fail_sha=$(find_failing_since "${repo}" "${name}")
      if [[ -n "${fail_sha}" ]]; then
        fail_display=$(printf "${RED}%-${W_FAILSINCE}s${RESET}" "${fail_sha:0:7}")
      else
        fail_display=$(printf "${DIM}%-${W_FAILSINCE}s${RESET}" "--")
      fi
    else
      fail_display=$(printf "${DIM}%-${W_FAILSINCE}s${RESET}" "--")
    fi

    # State transition detection & notification
    local wf_key prev_conclusion
    wf_key=$(echo "${name}" | tr ' ' '_')
    prev_conclusion=$(echo "${prev_state}" | jq -r --arg k "${wf_key}" '.[$k] // empty' 2>/dev/null || true)
    if [[ "${conclusion}" == "failure" && "${prev_conclusion}" == "success" ]]; then
      notify_failure "${name}" "${repo}"
    elif [[ "${conclusion}" == "success" && "${prev_conclusion}" == "failure" ]]; then
      notify_recovery "${name}" "${repo}"
    fi
    new_state=$(echo "${new_state}" | jq --arg k "${wf_key}" --arg v "${conclusion}" '.[$k] = $v')

    # Print row
    printf "│ %-${max_len}s │ %s │ %-${W_STARTED}s │ %-${W_FINISHED}s │ %-${W_DURATION}s │ %s │ %s │\n" \
      "${name}" "${status_display}" "${started_display}" "${finished_display}" "${duration_str}" "${eta_display}" "${fail_display}"
  done

  draw_border "${max_len}" "└" "┴" "┘"
  echo ""

  # Persist state
  local tmp
  tmp=$(mktemp)
  jq --arg k "${state_key}" --argjson v "${new_state}" '.[$k] = $v' "${STATE_FILE}" > "${tmp}" && mv "${tmp}" "${STATE_FILE}"
}

# ── Aggregate display (single table) ────────────────────────────
display_aggregate() {
  local now
  now=$(date '+%Y-%m-%d %H:%M:%S')

  echo ""
  if [[ "${WATCH}" == true ]]; then
    printf "${BOLD}${CYAN}  GitHub Actions ${RESET}${DIM}(${now})  ⟳ every ${WATCH_INTERVAL}s — Ctrl-C to stop${RESET}\n"
  else
    printf "${BOLD}${CYAN}  GitHub Actions ${RESET}${DIM}(${now})${RESET}\n"
  fi
  echo ""

  # Collect all rows: repo short_name + workflow data
  local all_rows=()
  local max_len=8

  for repo in "${REPOS[@]}"; do
    # Short name: strip org prefix
    local short_name
    short_name=$(echo "${repo}" | sed -E 's|.*/||')

    local runs
    runs=$(gh_fetch_runs "${repo}" --branch "${BRANCH}" --limit 100) || continue

    # Filter to only active workflows
    local active_ids
    active_ids=$(gh_active_workflow_ids "${repo}" 2>/dev/null) || active_ids="[]"
    if [[ "${active_ids}" != "[]" ]]; then
      runs=$(echo "${runs}" | jq --argjson ids "${active_ids}" \
        '[.[] | select(.workflowId as $wid | $ids | index($wid))]')
    fi

    local workflows
    workflows=$(echo "${runs}" | jq '
      group_by(.workflowId // .workflowName)
      | map(sort_by(.startedAt) | reverse | .[0])
      | sort_by(.workflowName)
    ')

    local count
    count=$(echo "${workflows}" | jq 'length')

    for (( i=0; i<count; i++ )); do
      local wf_name
      wf_name=$(echo "${workflows}" | jq -r ".[$i].workflowName" 2>/dev/null || echo "unknown")
      local label="${short_name}/${wf_name}"
      (( ${#label} > max_len )) && max_len=${#label}

      local row_json
      row_json=$(echo "${workflows}" | jq -c ".[$i]" 2>/dev/null)
      all_rows+=("${repo}|${label}|${row_json}")
    done
  done

  if [[ ${#all_rows[@]} -eq 0 ]]; then
    printf "  ${DIM}No workflow runs found${RESET}\n\n"
    return
  fi

  # Load full state for transition detection
  local agg_prev_state agg_new_state="{}"
  agg_prev_state=$(cat "${STATE_FILE}" 2>/dev/null || echo '{}')

  draw_border "${max_len}" "┌" "┬" "┐"

  printf "│ ${BOLD}%-${max_len}s${RESET} │ ${BOLD}%-${W_STATUS}s${RESET} │ ${BOLD}%-${W_STARTED}s${RESET} │ ${BOLD}%-${W_FINISHED}s${RESET} │ ${BOLD}%-${W_DURATION}s${RESET} │ ${BOLD}%-${W_ETA}s${RESET} │ ${BOLD}%-${W_FAILSINCE}s${RESET} │\n" \
    "Repo/Workflow" "Status" "Started" "Finished" "Duration" "ETA" "Fail Since"

  draw_border "${max_len}" "├" "┼" "┤"

  local prev_short=""

  for row in "${all_rows[@]}"; do
    local repo label row_json
    repo="${row%%|*}"
    local rest="${row#*|}"
    label="${rest%%|*}"
    row_json="${rest#*|}"

    local state_key
    state_key=$(echo "${repo}" | tr '/' '_')

    local name status conclusion started_at updated_at
    name=$(echo "${row_json}" | jq -r '.workflowName' 2>/dev/null || echo "unknown")
    status=$(echo "${row_json}" | jq -r '.status' 2>/dev/null || echo "unknown")
    conclusion=$(echo "${row_json}" | jq -r '.conclusion' 2>/dev/null || echo "unknown")
    started_at=$(echo "${row_json}" | jq -r '.startedAt' 2>/dev/null || echo "null")
    updated_at=$(echo "${row_json}" | jq -r '.updatedAt' 2>/dev/null || echo "null")

    # Separator between repos
    local cur_short="${label%%/*}"
    if [[ -n "${prev_short}" && "${cur_short}" != "${prev_short}" ]]; then
      draw_border "${max_len}" "├" "┼" "┤"
    fi
    prev_short="${cur_short}"

    # Time
    local started_display finished_display duration_str
    started_display=$(parse_time "${started_at}")
    if [[ "${status}" == "completed" ]]; then
      finished_display=$(parse_time "${updated_at}")
      local s_epoch f_epoch
      s_epoch=$(parse_epoch "${started_at}")
      f_epoch=$(parse_epoch "${updated_at}")
      if (( s_epoch > 0 && f_epoch > 0 )); then
        duration_str=$(format_duration $(( f_epoch - s_epoch )))
      else
        duration_str="--"
      fi
    elif [[ "${status}" == "queued" ]]; then
      finished_display="--"
      duration_str="queued"
    else
      finished_display="--"
      duration_str="running"
    fi

    # Status with color
    local status_display
    case "${status}:${conclusion}" in
      in_progress:*) status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "running")   ;;
      queued:*)      status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "queued")       ;;
      pending:*)     status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "pending")    ;;
      waiting:*)     status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "waiting")    ;;
      requested:*)   status_display=$(printf "${YELLOW}%-${W_STATUS}s${RESET}" "requested")  ;;
      *:success)     status_display=$(printf "${GREEN}%-${W_STATUS}s${RESET}" "pass")       ;;
      *:failure)     status_display=$(printf "${RED}%-${W_STATUS}s${RESET}" "FAIL")         ;;
      *:cancelled)   status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "cancelled")    ;;
      *)             status_display=$(printf "${DIM}%-${W_STATUS}s${RESET}" "${status}")     ;;
    esac

    # ETA
    local eta_display
    if [[ "${status}" == "in_progress" || "${status}" == "queued" ]]; then
      local est_seconds elapsed now_epoch remaining
      est_seconds=$(estimate_duration "${repo}" "${name}")
      if (( est_seconds > 0 )); then
        now_epoch=$(date +%s)
        local start_epoch
        start_epoch=$(parse_epoch "${started_at}")
        if (( start_epoch > 0 )); then
          elapsed=$(( now_epoch - start_epoch ))
          remaining=$(( est_seconds - elapsed ))
          if (( remaining > 0 )); then
            eta_display=$(printf "${YELLOW}%-${W_ETA}s${RESET}" "~$(format_duration ${remaining})")
          else
            eta_display=$(printf "${RED}%-${W_ETA}s${RESET}" "+$(format_duration $(( -remaining )))")
          fi
        else
          eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
        fi
      else
        eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
      fi
    else
      eta_display=$(printf "${DIM}%-${W_ETA}s${RESET}" "--")
    fi

    # Failing since
    local fail_display
    if [[ "${conclusion}" == "failure" ]]; then
      local fail_sha
      fail_sha=$(find_failing_since "${repo}" "${name}" || true)
      if [[ -n "${fail_sha}" ]]; then
        fail_display=$(printf "${RED}%-${W_FAILSINCE}s${RESET}" "${fail_sha:0:7}")
      else
        fail_display=$(printf "${DIM}%-${W_FAILSINCE}s${RESET}" "--")
      fi
    else
      fail_display=$(printf "${DIM}%-${W_FAILSINCE}s${RESET}" "--")
    fi

    # State transition detection & notification
    local wf_key prev_conclusion
    wf_key=$(echo "${name}" | tr ' ' '_')
    prev_conclusion=$(echo "${agg_prev_state}" | jq -r --arg rk "${state_key}" --arg wk "${wf_key}" '.[$rk][$wk] // empty' 2>/dev/null || true)
    if [[ "${conclusion}" == "failure" && "${prev_conclusion}" == "success" ]]; then
      notify_failure "${name}" "${repo}"
    elif [[ "${conclusion}" == "success" && "${prev_conclusion}" == "failure" ]]; then
      notify_recovery "${name}" "${repo}"
    fi
    agg_new_state=$(echo "${agg_new_state}" | jq --arg rk "${state_key}" --arg wk "${wf_key}" --arg v "${conclusion}" \
      '.[$rk] = ((.[$rk] // {}) | .[$wk] = $v)' 2>/dev/null || echo "${agg_new_state}")

    # Print row
    printf "│ %-${max_len}s │ %s │ %-${W_STARTED}s │ %-${W_FINISHED}s │ %-${W_DURATION}s │ %s │ %s │\n" \
      "${label}" "${status_display}" "${started_display}" "${finished_display}" "${duration_str}" "${eta_display}" "${fail_display}"
  done

  draw_border "${max_len}" "└" "┴" "┘"
  echo ""

  # Batch save state
  local tmp
  tmp=$(mktemp)
  jq -s '.[0] * .[1]' "${STATE_FILE}" <(echo "${agg_new_state}") > "${tmp}" 2>/dev/null && mv "${tmp}" "${STATE_FILE}" || rm -f "${tmp}"
}

# ── Main display (all repos) ────────────────────────────────────
display_all() {
  if [[ "${AGGREGATE}" == true ]]; then
    display_aggregate
    return
  fi

  local now
  now=$(date '+%Y-%m-%d %H:%M:%S')

  echo ""
  if [[ "${WATCH}" == true ]]; then
    printf "${BOLD}${CYAN}  GitHub Actions ${RESET}${DIM}(${now})  ⟳ every ${WATCH_INTERVAL}s — Ctrl-C to stop${RESET}\n"
  else
    printf "${BOLD}${CYAN}  GitHub Actions ${RESET}${DIM}(${now})${RESET}\n"
  fi
  echo ""

  for repo in "${REPOS[@]}"; do
    display_repo "${repo}" "${now}" || printf "  ${RED}Error fetching ${repo}${RESET}\n\n"
  done
}

# ── Run (once or watch) ─────────────────────────────────────────
if [[ "${WATCH}" == true ]]; then
  trap 'printf "\033[?25h\n${DIM}  Stopped.${RESET}\n"; exit 0' INT
  printf '\033[?25l'
  while true; do
    printf '\033[H\033[2J\033[3J' > /dev/tty
    display_all
    sleep "${WATCH_INTERVAL}"
  done
else
  display_all
fi
