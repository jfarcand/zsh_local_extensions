#!/usr/bin/env zsh
# Launcher for GitHub Copilot CLI with model selection.
# Uses a static model mapping (copilot no longer lists models in --help).

set -euo pipefail

# Model mapping — update these when copilot adds new models.
# Run `copilot` interactively to see the current model list.
typeset -A models=(
  [opus]="claude-opus-4.6-fast"
  [sonnet]="claude-sonnet-4"
  [gemini]="gemini-3-pro"
  [gpt]="gpt-5.4"
)

usage() {
  echo "Usage: cop [--opus|--sonnet|--gemini|--gpt] [copilot-options...]"
  echo ""
  echo "Model shortcuts:"
  for key in ${(k)models}; do
    printf "  --%-8s %s\n" "$key" "${models[$key]}"
  done
  echo ""
  echo "All other options are passed through to copilot."
  exit 1
}

family="sonnet"
passthrough=()

for arg in "$@"; do
  case "$arg" in
    --opus)    family="opus" ;;
    --sonnet)  family="sonnet" ;;
    --gemini)  family="gemini" ;;
    --gpt)     family="gpt" ;;
    --help|-h) usage ;;
    *)         passthrough+=("$arg") ;;
  esac
done

model="${models[$family]}"

echo "Using model: $model"
exec copilot --allow-all-tools --allow-all-paths --model="$model" "${passthrough[@]}"
