#!/usr/bin/env bash
# cclimits - Claude Code usage limits (session + weekly) with macOS notifications
#
# Usage:
#   cclimits                     # show usage once (and notify if a threshold was crossed)
#   cclimits -w [SECONDS]        # watch mode, refresh every N seconds (default 60)
#   cclimits --start N           # notifications start at N% (default 60)
#   cclimits --step N            # below critical, notify every N% (default 10)
#   cclimits --critical N        # from N% on, notify every 1% (default 90)
#   cclimits --no-alert          # display only, never notify
#   cclimits --retries N         # cap attempts on 429/5xx/network (default 0 = retry until it clears)
#   cclimits --test              # fire a test macOS notification and exit
#   cclimits --reset             # clear saved notification state
#
# Reads the Claude Code OAuth token from the macOS Keychain and calls the same
# usage endpoint the /usage command uses (does not consume usage). Notification
# state persists in ~/.local/state/cclimits so one-shot runs (cron/launchd) and
# watch mode both avoid re-notifying for the same threshold.

set -euo pipefail

WATCH=false
WATCH_INTERVAL=60
WATCH_MAX_SECONDS=21600   # auto-exit watch after 6h so a forgotten loop can't linger
START_AT=60
STEP=10
CRITICAL_AT=90
ALERT_ENABLED=true
FETCH_RETRIES=0          # 0 = retry until it clears (truncated backoff); N>=1 caps total attempts
RETRY_BASE=2             # base backoff seconds; grows 2,4,8… with jitter, capped at RETRY_MAX
RETRY_MAX=60             # cap on any single backoff sleep (so it plateaus, doesn't grow unbounded)
USAGE_URL="${CCLIMITS_URL:-https://api.anthropic.com/api/oauth/usage}"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/cclimits"
STATE_FILE="$STATE_DIR/state"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -w|--watch)
      WATCH=true
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        WATCH_INTERVAL="$2"
        shift
      fi
      shift
      ;;
    --start)
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        START_AT="$2"
        shift 2
      else
        echo "cclimits: --start requires a number" >&2
        exit 1
      fi
      ;;
    --step)
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        STEP="$2"
        shift 2
      else
        echo "cclimits: --step requires a number" >&2
        exit 1
      fi
      ;;
    --critical)
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        CRITICAL_AT="$2"
        shift 2
      else
        echo "cclimits: --critical requires a number" >&2
        exit 1
      fi
      ;;
    --no-alert)
      ALERT_ENABLED=false
      shift
      ;;
    --retries)
      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
        FETCH_RETRIES="$2"
        shift 2
      else
        echo "cclimits: --retries requires a number (0 = retry until it clears)" >&2
        exit 1
      fi
      ;;
    --test)
      osascript -e 'display notification "Notifications are working." with title "cclimits: test" sound name "Sosumi"'
      echo "cclimits: test notification sent (if nothing appeared, allow notifications for your terminal in System Settings → Notifications)"
      exit 0
      ;;
    --reset)
      rm -f "$STATE_FILE"
      echo "cclimits: notification state cleared"
      exit 0
      ;;
    -h|--help)
      sed -n '2,18p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *)
      echo "cclimits: unknown option '$1' (see --help)" >&2
      exit 1
      ;;
  esac
done

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

mkdir -p "$STATE_DIR"

state_get() {
  local key="$1" v=""
  if [[ -f "$STATE_FILE" ]]; then
    v=$(awk -F'\t' -v k="$key" '$1==k{print $2}' "$STATE_FILE" | tail -1)
  fi
  echo "${v:-0}"
}

state_set() {
  local key="$1" val="$2" tmp="${STATE_FILE}.tmp.$$"
  {
    [[ -f "$STATE_FILE" ]] && awk -F'\t' -v k="$key" '$1!=k' "$STATE_FILE"
    printf '%s\t%s\n' "$key" "$val"
  } > "$tmp"
  mv "$tmp" "$STATE_FILE"
}

# Map a percent to its notification level: 0 below START_AT, then STEP-sized
# bands (60, 70, 80), then every 1% from CRITICAL_AT up. A notification fires
# only when the level rises above the last one saved for that limit.
notify_level() {
  local pct="$1"
  if (( pct < START_AT )); then
    echo 0
  elif (( pct < CRITICAL_AT )); then
    local band=$(( pct / STEP * STEP ))
    (( band < START_AT )) && band=$START_AT
    echo "$band"
  else
    echo "$pct"
  fi
}

# "2026-07-16T17:19:59.672659+00:00" -> epoch (BSD date needs +0000, no colon)
iso_to_epoch() {
  local iso="$1"
  iso=$(echo "$iso" | sed -E 's/\.[0-9]+//; s/Z$/+0000/; s/([+-][0-9]{2}):([0-9]{2})$/\1\2/')
  date -j -f "%Y-%m-%dT%H:%M:%S%z" "$iso" +%s 2>/dev/null || echo 0
}

# Format an epoch as EDT (America/New_York) plus a human delta from now.
format_reset() {
  local epoch="$1"
  local now delta hrs mins delta_str when_str
  if (( epoch == 0 )); then
    echo "unknown"
    return
  fi
  now=$(date +%s)
  delta=$(( epoch - now ))
  (( delta < 0 )) && delta=0
  hrs=$(( delta / 3600 ))
  mins=$(( (delta % 3600) / 60 ))
  if (( hrs > 0 )); then
    delta_str=$(printf "%dh%02dm" "$hrs" "$mins")
  else
    delta_str=$(printf "%dm" "$mins")
  fi
  when_str=$(TZ="America/New_York" date -r "$epoch" "+%a %H:%M %Z")
  echo "${when_str} (in ${delta_str})"
}

fire_alert() {
  local label="$1" pct="$2" reset_epoch="$3"
  local title="cclimits: Claude usage"
  (( pct >= CRITICAL_AT )) && title="cclimits: Claude usage CRITICAL"
  local when
  when=$(TZ="America/New_York" date -r "$reset_epoch" "+%H:%M %Z" 2>/dev/null || echo "?")
  if command -v afplay >/dev/null 2>&1; then
    afplay /System/Library/Sounds/Sosumi.aiff >/dev/null 2>&1 &
  fi
  if command -v osascript >/dev/null 2>&1; then
    osascript -e "display notification \"${label} at ${pct}% — resets ${when}\" with title \"${title}\" sound name \"Sosumi\"" >/dev/null 2>&1 || true
  fi
}

# Seconds to wait before the next attempt: exponential (RETRY_BASE·2^(n-1),
# capped at RETRY_MAX) with up to ~1s of jitter so repeated callers desync.
# Honors a positive Retry-After header when it exceeds our own backoff; the
# server here sends "retry-after: 0", which we correctly ignore in favor of
# real backoff so we don't hot-loop.
backoff_delay() {
  local attempt="$1" retry_after="${2:-0}" delay jitter
  delay=$(( RETRY_BASE << (attempt - 1) ))
  (( delay > RETRY_MAX )) && delay=$RETRY_MAX
  if [[ "$retry_after" =~ ^[0-9]+$ ]] && (( retry_after > delay )); then
    delay=$retry_after
    (( delay > RETRY_MAX )) && delay=$RETRY_MAX
  fi
  jitter=$(( RANDOM % 1000 ))
  awk -v d="$delay" -v j="$jitter" 'BEGIN{ printf "%.2f", d + j/1000 }'
}

fetch_usage() {
  local token resp http hdr attempt lbl retry_after delay
  token=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
    | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null) || true
  if [[ -z "$token" ]]; then
    echo "cclimits: no OAuth token in Keychain (item 'Claude Code-credentials') — is Claude Code logged in?" >&2
    return 1
  fi

  hdr="$STATE_DIR/.hdr.$$"
  attempt=0
  while :; do
    attempt=$(( attempt + 1 ))
    if resp=$(curl -s --max-time 15 -D "$hdr" -w $'\n%{http_code}' "$USAGE_URL" \
        -H "Authorization: Bearer $token" \
        -H "anthropic-beta: oauth-2025-04-20"); then
      http="${resp##*$'\n'}"
      USAGE_JSON="${resp%$'\n'*}"
    else
      http="000"          # curl itself failed (timeout / DNS / connection)
      USAGE_JSON=""
    fi

    case "$http" in
      200)
        if echo "$USAGE_JSON" | jq -e '.limits' >/dev/null 2>&1; then
          rm -f "$hdr"
          return 0
        fi
        echo "cclimits: HTTP 200 but response had no .limits — unexpected payload" >&2
        rm -f "$hdr"
        return 1
        ;;
      401)
        echo "cclimits: token expired — run any Claude Code command (it refreshes the token), then retry" >&2
        rm -f "$hdr"
        return 1
        ;;
      429|500|502|503|504|000)
        lbl="HTTP $http"
        [[ "$http" == "000" ]] && lbl="network error"
        # Optional hard cap on attempts (--retries N, N>0). Default 0 = keep going.
        if (( FETCH_RETRIES > 0 && attempt >= FETCH_RETRIES )); then
          echo "cclimits: still failing (${lbl}) after $attempt attempts — try again shortly" >&2
          rm -f "$hdr"
          return 1
        fi
        retry_after=$(awk 'tolower($1)=="retry-after:"{gsub(/\r/,"",$2); print $2; exit}' "$hdr" 2>/dev/null)
        delay=$(backoff_delay "$attempt" "$retry_after")
        # Never retry past the shared run ceiling: even "retry forever" stays
        # bounded by WATCH_MAX_SECONDS so a stuck endpoint can't linger (guards
        # the iTerm working-set freeze the same way the watch auto-exit does).
        if (( $(date +%s) + ${delay%.*} >= RUN_DEADLINE )); then
          echo "cclimits: still failing (${lbl}) after ${attempt} attempts / ~$(( WATCH_MAX_SECONDS / 3600 ))h ceiling — giving up" >&2
          rm -f "$hdr"
          return 1
        fi
        if (( FETCH_RETRIES > 0 )); then
          printf "${DIM}cclimits: %s — retry %d/%d in %ss…${RESET}\n" \
            "$lbl" "$attempt" "$(( FETCH_RETRIES - 1 ))" "$delay" >&2
        else
          printf "${DIM}cclimits: %s — retry #%d in %ss (until it clears)…${RESET}\n" \
            "$lbl" "$attempt" "$delay" >&2
        fi
        sleep "$delay"
        continue
        ;;
      *)
        echo "cclimits: unexpected response (HTTP $http)" >&2
        rm -f "$hdr"
        return 1
        ;;
    esac
  done
}

print_limit() {
  local label="$1" pct="$2" reset_epoch="$3"
  local color="$GREEN" width=24 filled bar
  (( pct >= START_AT )) && color="$YELLOW"
  (( pct >= CRITICAL_AT )) && color="$RED"
  filled=$(( pct * width / 100 ))
  (( filled > width )) && filled=$width
  bar=$(printf '%*s' "$filled" '' | tr ' ' '█')$(printf '%*s' $(( width - filled )) '' | tr ' ' '░')
  printf "${BOLD}%-22s${RESET} ${color}%s %3d%%${RESET}  resets ${BOLD}%s${RESET}\n" \
    "$label" "$bar" "$pct" "$(format_reset "$reset_epoch")"
}

show_status() {
  fetch_usage || return 1

  local now_str
  now_str=$(TZ="America/New_York" date "+%Y-%m-%d %H:%M:%S %Z")
  printf "${DIM}as of %s — alerts from %d%%, every %d%%, every 1%% from %d%%${RESET}\n" \
    "$now_str" "$START_AT" "$STEP" "$CRITICAL_AT"

  local kind group pct resets scope key label reset_epoch level prev
  while IFS=$'\t' read -r kind group pct resets scope; do
    key="$kind"
    case "$kind" in
      session)       label="Session (5h)" ;;
      weekly_all)    label="Weekly (all models)" ;;
      weekly_scoped) label="Weekly (${scope:-scoped})"; key="${kind}:${scope}" ;;
      *)             label="$kind" ;;
    esac

    reset_epoch=$(iso_to_epoch "$resets")
    print_limit "$label" "$pct" "$reset_epoch"

    level=$(notify_level "$pct")
    prev=$(state_get "$key")
    if (( level > prev )); then
      if $ALERT_ENABLED; then
        fire_alert "$label" "$pct" "$reset_epoch"
        printf "  ${RED}${BOLD}⚠ notified: %s at %d%%${RESET}\n" "$label" "$pct"
      fi
      state_set "$key" "$level"
    elif (( level < prev )); then
      # Usage dropped (window reset) — re-arm so the next climb notifies again.
      state_set "$key" "$level"
    fi
  done < <(echo "$USAGE_JSON" | jq -r \
    '.limits[] | [.kind, .group, ((.percent // 0) | floor), (.resets_at // ""), (.scope.model.display_name // "")] | @tsv')
}

# Absolute wall-clock ceiling shared by the watch loop and the fetch retry loop.
# Nothing this invocation does outlives WATCH_MAX_SECONDS — a forgotten watch OR
# an endless retry against a stuck endpoint both stop here (iTerm freeze guard).
RUN_DEADLINE=$(( $(date +%s) + WATCH_MAX_SECONDS ))

if $WATCH; then
  # Alternate screen buffer so refreshes never accumulate in iTerm scrollback;
  # restore the primary screen on any exit, auto-stop after WATCH_MAX_SECONDS.
  trap 'printf "\033[?1049l"' EXIT
  printf '\033[?1049h'
  watch_deadline=$RUN_DEADLINE
  while true; do
    printf '\033[H\033[2J'
    show_status || true
    if (( $(date +%s) >= watch_deadline )); then
      printf "\n${DIM}auto-exited after %ds — re-run to keep watching${RESET}\n" "$WATCH_MAX_SECONDS"
      break
    fi
    printf "\n${DIM}refreshing every %ds — Ctrl-C to stop${RESET}\n" "$WATCH_INTERVAL"
    sleep "$WATCH_INTERVAL"
  done
else
  show_status
fi
